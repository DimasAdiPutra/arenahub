@baseUrl = http://localhost:5000/api

### 1. Login Sebagai Owner/Admin untuk Mendapatkan Token
# @name loginOwner
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "hendra_owner@mail.com",
  "password": "password123"
}

### Tampung token hasil login di atas ke variabel otomatis
@tokenOwner = {{loginOwner.response.body.data.token}}


### ─────────────────────────────────────────────────────────────
### DATA MASTER KATEGORI
### ─────────────────────────────────────────────────────────────

### 2. Buat Kategori Awal Secara Manual (Karena DB Masih Kosong)
# @name createCategoryManual
POST {{baseUrl}}/categories
Content-Type: application/json
Authorization: Bearer {{tokenOwner}}

{
  "name": "Futsal"
}

### Tampung ID Kategori yang baru dibuat secara otomatis ke variabel!
@idKategoriFutsal = {{createCategoryManual.response.body.data._id}}


### 3. Ambil Semua Kategori yang Ada di Database
# Sekarang rute ini akan menampilkan kategori "Futsal" yang baru dibuat
GET {{baseUrl}}/categories


